# ============ DB ============
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# event-service가 config-server yaml의 ${DB_USER} / ${DB_PASSWORD} 플레이스홀더 해소에 사용
DB_USER=
DB_PASSWORD=

# ============ Config Server ============
# config-server가 바라보는 git repo URL (config-server 담당자 설정)
CONFIG_USERNAME=
CONFIG_PASSWORD=
CONFIG_URL=
CONFIG_SERVER_URL=

# ============ Git (config-server 빌드 시 필요) ============
GIT_USERNAME=
GIT_TOKEN=

# ============ JWT ============
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=
JWT_REFRESH_TOKEN_EXPIRATION=
INTERNAL_API_TOKEN=

# ============ OpenAI (ai-service) ============
OPENAI_API_KEY=

# ============ Notification (notification-service) ============
HOST=
PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

# ============ Monitoring ============
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=
