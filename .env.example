# ============ DB ============
POSTGRES_USER=festie
POSTGRES_PASSWORD=1234
POSTGRES_DB=festie

# event-service가 config-server yaml의 ${DB_USER} / ${DB_PASSWORD} 플레이스홀더 해소에 사용
DB_USER=festie
DB_PASSWORD=1234

# ============ Config Server ============
CONFIG_USERNAME=festie          # 팀 공유값
CONFIG_PASSWORD=festiepw        # 팀 공유값
CONFIG_URL=                     # config-server가 바라보는 git repo URL (config-server 담당자 설정)

# ============ Git (config-server 빌드 시 필요) ============
GIT_USERNAME=
GIT_TOKEN=

# ============ JWT ============
JWT_SECRET=

# ============ OpenAI (ai-service) ============
OPENAI_API_KEY=

# ============ Notification (notification-service) ============
HOST=
PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
